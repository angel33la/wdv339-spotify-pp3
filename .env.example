# Root-level environment variables (used when running from repo root)

# Server
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_different_long_random_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-render-app.onrender.com/api/auth/callback
CLIENT_URL=https://your-render-app.onrender.com
YOUTUBE_API_KEY=your_youtube_api_key

# Client
REACT_APP_API_URL=https://your-render-app.onrender.com
